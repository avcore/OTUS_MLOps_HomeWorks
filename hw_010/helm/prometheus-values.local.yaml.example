# prometheus-values.local.yaml — РЕАЛЬНЫЕ секреты (Telegram bot, ...).
# Скопируй этот файл в prometheus-values.local.yaml и подставь свои значения.
# .gitignore исключает *.local.yaml из коммита.
#
# helm install/upgrade со ВТОРЫМ values-файлом мержит то, что ниже,
# поверх дефолтного prometheus-values.yaml.

alertmanager:
  config:
    receivers:
      # ВАЖНО: имя должно совпадать с тем, что в prometheus-values.yaml ("tg-admin")
      - name: "tg-admin"
        telegram_configs:
          - bot_token: "PASTE_BOT_TOKEN_HERE"      # ⚠️ от @BotFather
            chat_id: PASTE_CHAT_ID_HERE_NUMERIC    # ⚠️ числовой, БЕЗ кавычек
            send_resolved: true
            parse_mode: "HTML"
            message: |
              <b>🚨 {{ .CommonLabels.alertname }}</b>
              <i>severity:</i> {{ .CommonLabels.severity }}
              {{ range .Alerts -}}
              • {{ .Annotations.summary }}
              {{ end }}
